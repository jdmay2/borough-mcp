{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"declaration": true,
		"sourceMap": true,
		"rootDir": ".",
		"outDir": "dist",
		"types": [
			"node"
		],
		"lib": [
			"ES2022"
		]
	},
	"include": [
		"src",
		"test"
	]
}
